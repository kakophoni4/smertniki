# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Telegram user id админа (можно несколько через запятую)
ADMIN_IDS=123456789

# Расписание проверок (cron, Europe/Moscow по умолчанию)
# Два раза в день: 10:00 и 18:00
CHECK_CRON=0 10,18 * * *

# Пауза между запросами к Rusprofile (секунды) — не долбим сайт
REQUEST_DELAY_SEC=3.0

# Таймаут HTTP к Rusprofile
HTTP_TIMEOUT_SEC=30

# База (sqlite по умолчанию, для продакшена можно postgres)
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# Папка выписок ЕГРЮЛ: одна PDF на ОГРН, при новой проверке старая перезаписывается
VYPISKI_DIR=./data/vypiski

# Сколько последних check_results хранить на лавку
KEEP_CHECK_RESULTS=5

# Часовой пояс
TIMEZONE=Europe/Moscow

# User-Agent для запросов
USER_AGENT=Mozilla/5.0 (compatible; LavkiMonitor/1.0; +https://t.me/)
